{
  "name": "zenius-desktop",
  "desktopName": "zenius-desktop.desktop",
  "version": "0.1.0",
  "description": "Desktop wrapper for https://www.zenius.net/",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "start:no-sandbox": "electron . --no-sandbox",
    "version:print": "node -p \"require('./package.json').version\"",
    "build:linux": "electron-builder --linux AppImage",
    "build:binary": "npm run build:linux",
    "build:mac": "electron-builder --mac dmg",
    "build:win": "electron-builder --win nsis",
    "test": "node --test",
    "coverage": "c8 --all --include=src/**/*.js --check-coverage --lines 100 --functions 100 --branches 100 --statements 100 node --test",
    "dist": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "net.zenius.desktop",
    "productName": "Zenius",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "src/**/*",
      "assets/icon.png",
      "assets/icon.ico",
      "assets/icon.icns",
      "assets/icons/**/*",
      "LICENSE",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Education",
      "icon": "assets/icons",
      "executableName": "zenius-desktop",
      "desktop": {
        "entry": {
          "Name": "Zenius",
          "Icon": "zenius-desktop",
          "StartupWMClass": "zenius-desktop"
        }
      }
    },
    "mac": {
      "icon": "assets/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    }
  },
  "keywords": [
    "electron",
    "zenius",
    "desktop"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "c8": "^10.1.3",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  }
}
